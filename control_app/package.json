{
  "name": "plsk-remote-ssh-manager",
  "version": "0.1.0",
  "description": "A simple Electron app for connecting to a Jetson through Tailscale and SSH.",
  "main": "electron/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "vite build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "electron": "^39.8.10",
    "vite": "^6.4.2"
  }
}
